{
    "name": "image-preprocess-husam-both",
    "displayName": "Image Preprocess husam both",
    "description": "Image Preprocess Application",
    "attributes": {
        "Provider": "Dataloop"
    },
    "version": "3.0.2",
    "scope": "project",
    "components": {
        "modules": [
            {
                "name": "img_module",
                "entryPoint": "img-preprocess/main.py",
                "className": "ServiceRunner",
                "initInputs": [],
                "functions": [
                    {
                        "name": "run",
                        "description": "run image preprocess - metadata extraction and thumbnail creation",
                        "input": [
                            {
                                "name": "item",
                                "type": "Item"
                            }
                        ],
                        "output": []
                    },
                    {
                        "name": "test",
                        "input": [],
                        "output": [],
                        "description": "test the package"
                    }
                ]
            },
            {
                "name": "tiff_module",
                "entryPoint": "tiff-preprocess/main.py",
                "className": "ServiceRunner",
                "initInputs": [],
                "functions": [
                    {
                        "name": "run",
                        "description": "convert tiff to png",
                        "input": [
                            {
                                "name": "item",
                                "type": "Item"
                            }
                        ],
                        "output": []
                    },
                    {
                        "name": "test",
                        "input": [],
                        "output": [],
                        "description": "convert tiff test"
                    }
                ]
            }
        ],
        "services": [
            {
                "name": "image-preprocess-husam",
                "moduleName": "img_module",
                "podType": "regular-s",
                "runtime": {
                    "runnerImage": "gcr.io/viewo-g/piper/agent/runner/apps/image-preprocess:0.0.1",
                    "concurrency": 2,
                    "autoscaler": {
                        "type": "rabbitmq",
                        "minReplicas": 1,
                        "maxReplicas": 100,
                        "queueLength": 20
                    }
                },
                "executionTimeout": 3600,
                "drainTime": 600,
                "onReset": "failed"
            },
            {
                "name": "tiff-converter-husam",
                "moduleName": "tiff_module",
                "podType": "regular-m",
                "runtime": {
                    "runnerImage": "gcr.io/viewo-g/piper/agent/runner/apps/image-preprocess:0.0.1",
                    "concurrency": 10,
                    "autoscaler": {
                        "type": "rabbitmq",
                        "minReplicas": 0,
                        "maxReplicas": 19,
                        "queueLength": 30
                    },
                    "preemptible": true
                },
                "executionTimeout": 3600,
                "drainTime": 600,
                "onReset": "rerun"
            }
        ],
        "triggers": [
            {
                "name": "image-preprocess",
                "type": "Event",
                "template": true,
                "activation": {
                    "autoClone": true,
                    "cloneActiveDefault": true,
                    "overridable": false
                },
                "applyOnExistingProjects": true,
                "activateOnExistingProjects": false,
                "spec": {
                    "resource": "Item",
                    "actions": ["Created", "Clone"],
                    "executionMode": "Once",
                    "filter": {
                        "$and": [
                            {"metadata.system.mimetype": "image/*"},
                            {"metadata.system.mimetype": {"$ne": "image/tiff"}},
                            {"hidden": false},
                            {"type": "file"}
                        ]
                    },
                    "operation": {
                        "type": "function",
                        "functionName": "run",
                        "serviceName": "image-preprocess"
                    },
                    "input": {
                        "metadata_only": false,
                        "thumbnail_only": false,
                        "thumbnail_size": 128,
                        "max_file_size_mb": 100,
                        "extract_exif": true,
                        "extract_gps": true
                    }
                }
            },
            {
                "name": "tiff-converter",
                "type": "Event",
                "template": true,
                "activation": {
                    "autoClone": true,
                    "cloneActiveDefault": true,
                    "overridable": false
                },
                "applyOnExistingProjects": true,
                "activateOnExistingProjects": false,
                "spec": {
                    "resource": "Item",
                    "actions": ["Created"],
                    "executionMode": "Once",
                    "filter": {
                        "$and": [
                            {"metadata.system.mimetype": "image/tiff"},
                            {"hidden": false},
                            {"type": "file"}
                        ]
                    },
                    "operation": {
                        "type": "function",
                        "functionName": "run",
                        "serviceName": "tiff-converter"
                    },
                    "input": {
                        "mode": "full",
                        "create_png_modality": true,
                        "thumbnail_size": 128,
                        "max_file_size_mb": 2000,
                        "max_output_dimensions": null,
                        "normalization_percentile": [0, 100],
                        "vis_bands": [1, 2, 3],
                        "extract_exif": true,
                        "extract_gps": true
                    }
                }
            }
        ]
    }
}